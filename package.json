{
  "name": "dnd-session-manager",
  "version": "1.0.0",
  "description": "Local DnD campaign and session manager",
  "main": "server.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch --watch-path=server server/server.js",
    "client": "vite"
  },
  "keywords": [
    "dnd",
    "campaign",
    "session",
    "manager",
    "node",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.17.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "sass": "^1.77.0",
    "sass-embedded": "^1.98.0",
    "vite": "^5.4.2"
  }
}
