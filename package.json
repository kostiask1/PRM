{
  "name": "dnd-session-manager",
  "version": "1.0.0",
  "description": "Local DnD campaign and session manager",
  "main": "server.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch --watch-path=server --watch-path=.env server/server.js",
    "client": "vite",
    "lint": "eslint . && npm run check:uk",
    "check:uk": "node scripts/check-ukrainian-encoding.mjs"
  },
  "keywords": [
    "dnd",
    "campaign",
    "session",
    "manager",
    "node",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.17.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-list": "^0.8.17",
    "react-markdown": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "sass": "^1.77.0",
    "sass-embedded": "^1.98.0",
    "vite": "^5.4.2"
  }
}
