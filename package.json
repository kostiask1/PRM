{
  "name": "dnd-session-manager",
  "version": "1.0.0",
  "description": "Local DnD campaign and session manager",
  "main": "server.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch --watch-path=server.js server.js",
    "client": "vite"
  },
  "keywords": [
    "dnd",
    "campaign",
    "session",
    "manager",
    "node",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.2"
  }
}